LOG_LEVEL=INFO

OLLAMA_BASE_URL=http://host.docker.internal:11434
EMBEDDING_MODEL=nomic-embed-text

POSTGRES_URL=postgresql+asyncpg://dialogue_bot:dialogue_bot@postgres:5432/dialogue_bot

DOCUMENT_SEARCHER_URL=http://document_searcher:8091
DOCUMENT_SEARCHER_API_KEY=your_search_api_key_here
DOCUMENT_SEARCHER_DEFAULT_COLLECTION=documents
FILE_VIEWER_URL=http://file_viewer:8092
WEB_SEARCHER_URL=http://web_searcher:8093
IMAGE_GENERATOR_URL=http://image_generator:8094
FILE_CONVERTER_URL=http://file_converter:8095

TOOL_REQUEST_TIMEOUT_SECONDS=45
HISTORY_SEARCH_LIMIT=5

# Shared Bearer token — must match MCP_AUTH_TOKEN in dialogue-agent
MCP_AUTH_TOKEN=change-me-to-a-strong-random-secret
